{
  "name": "nats",
  "category": "outputs",
  "status": "stable",
  "summary": "Publishes messages to a NATS subject.",
  "bodyKind": "object",
  "replicaSafety": "safe",
  "configSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["urls", "subject"],
    "properties": {
      "urls": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 1,
        "description": "List of NATS server URLs (e.g. [\"nats://localhost:4222\"])."
      },
      "subject": {
        "type": "string",
        "description": "Subject to publish to. Supports Bloblang interpolation."
      },
      "max_in_flight": {
        "type": "integer",
        "minimum": 1,
        "default": 64,
        "description": "Maximum number of messages to send in parallel."
      }
    },
    "additionalProperties": false
  }
}
